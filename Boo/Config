Config:label({name = "Show Gui"}):keybind({default = Enum.KeyCode.RightControl, state = true, mode = "Toggle", callback = function(Value) library:toggle(Value) end})
Config:toggle({name = "Show Watermark", state = false, callback = function(Value) watermark.Visible = Value end})
Config:toggle({name = "Show Keybind List", state = false, callback = function(Value) KeybindContainer.Visible = Value end})
Config:button({name = "Unload", confirm = true, callback = function() library:Unload() end})

local last = ""
library:connect(RunService.Heartbeat, function()
    local time = os.date("%H:%M:%S")
    local ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
    local text = string.format("Boo | beta | %d ms | %s", ping, time)
    if text ~= last then
        last = text
        library:setwatermark(text)
    end
end)
