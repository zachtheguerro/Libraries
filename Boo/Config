-- Config -- 
local Config = window:tab({name = "Config"})

local cfgname = Config:textbox({name = "Config Name", flag = "cfgname", callback = function() end})

local cfglist = Config:dropdown({name = "Config List", flag = "selectedcfg", options = library.ConfigManager:RefreshConfigList(), max = 1, callback = function() end})

local function getcfglist()
    if cfglist and type(cfglist) == "table" and type(cfglist.setoptions) == "function" and type(cfglist.set) == "function" then
        return cfglist
    end

    local item = library.items["selectedcfg"]
    if item and type(item) == "table" and type(item.setoptions) == "function" and type(item.set) == "function" then
        cfglist = item
        return item
    end

    return nil
end

local function updatecfglist(selectedName)
    local list = getcfglist()
    if not list then
        warn("Config List dropdown is nil or invalid")
        return false
    end

    list:setoptions(library.ConfigManager:RefreshConfigList())

    if selectedName ~= nil then
        list:set(selectedName)
    end

    return true
end

local function getselectedcfg()
    local selected = library.flags["selectedcfg"]
    local name = selected

    if type(selected) == "table" then
        name = selected[1]
    end

    if not name or name == "" then
        return nil
    end

    return name
end

task.defer(function()
    updatecfglist()
end)

Config:button({name = "Create Config", callback = function()
    local name = library.flags["cfgname"]

    local success, message = library.ConfigManager:CreateConfig(name)
    if success then
        updatecfglist(name)

        library:Notify({
            text = "Created config",
            time = 3,
            highlights = {tostring(name)}
        })

        local success2, message2 = library.ConfigManager:SaveConfig(name)
        if success2 then
            updatecfglist(name)

            library:Notify({
                text = "Saved config",
                time = 3,
                highlights = {tostring(name)}
            })
        else
            library:Notify({
                text = "Save failed",
                time = 3,
                highlights = {tostring(message2)}
            })
        end
    else
        library:Notify({
            text = "Create failed",
            time = 3,
            highlights = {tostring(message)}
        })
    end
end})

Config:button({
    name = "Save Config",
    confirm = true,
    callback = function()
        local name = getselectedcfg()

        if not name then
            library:Notify({
                text = "Save failed",
                time = 3,
                highlights = {"no config selected"}
            })
            return
        end

        local success, message = library.ConfigManager:SaveConfig(name)
        if success then
            updatecfglist(name)

            library:Notify({
                text = "Saved config",
                time = 3,
                highlights = {tostring(name)}
            })
        else
            library:Notify({
                text = "Save failed",
                time = 3,
                highlights = {tostring(message)}
            })
        end
    end
})

