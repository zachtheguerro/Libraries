Config:label({name = "Accent Color"}):colorpicker({color = library.accent, callback = function(Value)
    library:updateColorGroup({value = Value, store = "accent", accentMode = true})
end})

Config:label({name = "Background Color"}):colorpicker({color = library.backgroundcolor, callback = function(Value)
    library:updateColorGroup({value = Value, store = "backgroundcolor", propsAttribute = "BackgroundProps"})
end})

Config:label({name = "Content Color"}):colorpicker({color = library.contentcolor, callback = function(Value)
