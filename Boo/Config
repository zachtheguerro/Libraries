-- Config -- 
local Config = window:tab({name = "Config"})

local cfgname = Config:textbox({name = "Config Name", flag = "cfgname", callback = function() end})
local cfglist = Config:dropdown({name = "Config List", flag = "selectedcfg", options = ConfigManager:RefreshConfigList(), max = 1, callback = function() end})

Config:button({name = "Create Config", callback = function()
    local name = library.flags["cfgname"]
    local success, message = ConfigManager:CreateConfig(name)
    if success then
        cfglist:setoptions(ConfigManager:RefreshConfigList())
        cfglist:set(name)
        library:Notify({
            text = "Created config",
            time = 3,
            highlights = {tostring(name)}
        })
        local success2, message2 = ConfigManager:SaveConfig(name)
        if success2 then
            cfglist:setoptions(ConfigManager:RefreshConfigList())
            cfglist:set(name)
            library:Notify({
                text = "Saved config",
                time = 3,
                highlights = {tostring(name)}
            })
        else
            library:Notify({
                text = "Save failed",
                time = 3,
                highlights = {tostring(message2)}
            })
        end
    else
        library:Notify({
            text = "Create failed",
            time = 3,
            highlights = {tostring(message)}
        })
    end
end})

Config:button({name = "Save Config", confirm = true, callback = function()
    local selected = library.flags["selectedcfg"]
    local name = selected
    if type(selected) == "table" then
        name = selected[1]
    end
    local success, message = ConfigManager:SaveConfig(name)
    if success then
        cfglist:setoptions(ConfigManager:RefreshConfigList())
        cfglist:set(name)
        library:Notify({
            text = "Saved config",
            time = 3,
            highlights = {tostring(name)}
        })
    else
        library:Notify({
            text = "Save failed",
            time = 3,
            highlights = {tostring(message)}
        })
    end
end})

Config:button({name = "Load Config", confirm = true, callback = function()
    local selected = library.flags["selectedcfg"]
    local name = selected
    if type(selected) == "table" then
        name = selected[1]
    end
    if not name or name == "" then
        library:Notify({
            text = "Load failed",
            time = 3,
            highlights = {"no config selected"}
        })
        return
    end
    local success, message = ConfigManager:LoadConfig(name)
    if success then
        library:Notify({
            text = "Loaded config",
            time = 3,
            highlights = {tostring(name)}
        })
    else
        library:Notify({
            text = "Load failed",
            time = 3,
            highlights = {tostring(message)}
        })
    end
end})

Config:button({name = "Delete Config", confirm = true, callback = function()
    local selected = library.flags["selectedcfg"]
    local name = selected
    if type(selected) == "table" then
        name = selected[1]
    end
    if not name or name == "" then
        library:Notify({
            text = "Delete failed",
            time = 3,
            highlights = {"no config selected"}
        })
        return
    end
    local success, message = ConfigManager:DeleteConfig(name)
    if success then
        cfglist:setoptions(ConfigManager:RefreshConfigList())
        cfglist:set(nil)
        library:Notify({
            text = "Deleted config",
            time = 3,
            highlights = {tostring(name)}
        })
    else
        library:Notify({
            text = "Delete failed",
            time = 3,
            highlights = {tostring(message)}
        })
    end
end})

